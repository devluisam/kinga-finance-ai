# ── Banco de dados ──────────────────────────────────────────────────────────
# Deixe vazio para usar SQLite local (data/kinga_finance.db)
DATABASE_URL=

# ── Dashboard → URL da API ───────────────────────────────────────────────────
API_URL=http://localhost:8000

# ── WhatsApp via Twilio ──────────────────────────────────────────────────────
# 1. Crie conta em https://twilio.com
# 2. Ative o WhatsApp Sandbox em: Console > Messaging > Try it out > Send a WhatsApp message
# 3. Preencha as variáveis abaixo com os dados do painel Twilio

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número do Twilio Sandbox (padrão abaixo) ou seu número aprovado pela Meta
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 4. Configure o webhook do Twilio apontando para:
#    https://SEU-DOMINIO/whatsapp/webhook
#    (use ngrok para testes locais: ngrok http 8000)
